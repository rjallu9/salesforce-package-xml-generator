{
  "name": "salesforce-package-xml-generator",
  "displayName": "Salesforce Package.xml Generator",
  "description": "This extension is to streamline the creation of Package.xml files for Salesforce deployments.",
  "publisher": "RamuJallu",
  "repository": "https://github.com/rjallu9/salesforce-package-xml-generator",
  "bugs": {
    "url": "https://github.com/rjallu9/salesforce-package-xml-generator/issues"
  },
  "license": "BSD-3-Clause",
  "version": "1.0.1",
  "icon": "logo.png",
  "keywords": [
    "sfdx",
    "salesforce",
    "salesforce package.xml",
    "sf",
    "sf package"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "salesforce-package-xml-generator.build",
        "title": "Build Package.xml",
        "category": "SFDX Package.xml Generator"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "npm run compile && terser src/assets/index.js -o out/assets/index.js -c -m && esbuild src/assets/index.css --minify --outfile=out/assets/index.css&& terser out/extension.js -o out/extension-min.js -c -m && del out\\extension.js && ren out\\extension-min.js extension.js   && vsce package",
    "build": "npm run compile && xcopy .\\src\\assets .\\out\\assets /s /y"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "xml2js": "^0.6.2"
  }
}
